# Django Configuration
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,localhost:3000

# PostgreSQL Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=Santacruzcomputer
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# CORS - Frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# JWT
JWT_SECRET=your-jwt-secret-key-here

# Brevo - Envío de correos transaccionales (recuperación de contraseña / OTP)
# La clave (xkeysib-...) se obtiene en Brevo -> "SMTP y API" -> "Claves API".
# El remitente (BREVO_FROM_EMAIL) DEBE estar verificado en Brevo -> "Senders".
BREVO_API_KEY=xkeysib-your-api-key-here
BREVO_FROM_EMAIL=tu-correo-verificado@dominio.com
BREVO_FROM_NAME=Santa Cruz Computer
BREVO_OTP_SUBJECT=Código de recuperación - Santa Cruz Computer
